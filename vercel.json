{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/**/*.py": {
      "maxDuration": 60,
      "excludeFiles": "{tests/**,alembic/**,docker/**,docs/**,scripts/**,.venv/**,.pytest_cache/**,.ruff_cache/**,**/*.md}"
    }
  }
}
