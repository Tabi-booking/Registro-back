# Application
APP_NAME=Tabi Formulario API
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false

# Server (local only — Vercel ignores HOST/PORT)
HOST=0.0.0.0
PORT=8001

# PostgreSQL (Supabase)
DB_HOST=db.bakkcbqdcuktgmzztxcr.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_supabase_password_here
DB_NAME=postgres
DB_SSLMODE=require
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# Vercel / serverless: use Supabase connection pooler (Settings → Database → Connection pooling)
# DB_HOST=aws-0-us-east-1.pooler.supabase.com
# DB_PORT=6543
# DB_USE_POOLER=true

# Redis (optional — rate limit + onboarding cache; fails open if unavailable)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_ONBOARDING_STATUS=60

# Vercel: use Upstash Redis or similar (full URL)
# REDIS_CONNECTION_URL=rediss://default:token@host.upstash.io:6379

# JWT — generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-64-char-string-in-production-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated). On Vercel add your frontend URL(s):
# CORS_ORIGINS=https://tu-front.vercel.app,https://registro.tabi.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_ONBOARDING=60/minute

# File uploads
MAX_FILE_SIZE_MB=10
STORAGE_BUCKET=restaurant-documents

# Supabase Storage (required for real presigned uploads)
STORAGE_URL=https://bakkcbqdcuktgmzztxcr.supabase.co/storage/v1
SUPABASE_URL=https://bakkcbqdcuktgmzztxcr.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
